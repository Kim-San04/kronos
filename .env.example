# KRONOS — Configuration des clés API
# Copier ce fichier en .env et renseigner les clés

# GitHub — Pour scanner les repos, commits, orgs
# Créer sur https://github.com/settings/tokens
GITHUB_TOKEN=

# Groq — Analyse IA (llama-3.3-70b)
# Obtenir sur https://console.groq.com
GROQ_API_KEY=

# Hunter.io — Recherche d'emails professionnels
# Obtenir sur https://hunter.io/api-keys
HUNTER_API_KEY=

# Have I Been Pwned — Vérification de fuites
# Obtenir sur https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Shodan — Scan infrastructure
# Obtenir sur https://account.shodan.io
SHODAN_API_KEY=
